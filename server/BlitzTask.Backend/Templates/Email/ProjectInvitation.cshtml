@model BlitzTask.Backend.Features.ProjectMembers.ProjectInvitationModel

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8"/>
    <style>
            body {
                font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
                line-height: 1.6;
                color: #333;
                max-width: 600px;
                margin: 0 auto;
                padding: 20px;
            }
            .container {
                background-color: #f9fafb;
                border-radius: 8px;
                padding: 20px;
            }
            .header {
                text-align: center;
                margin-bottom: 30px;
            }
            .logo {
                font-size: 28px;
                font-weight: bold;
                color: #000;
            }
            h1 {
                color: #1f2937;
                font-size: 24px;
                margin: 20px 0;
            }
            .content {
                background-color: #fff;
                padding: 20px;
                border-radius: 6px;
                margin-bottom: 20px;
            }
            .button {
                display: inline-block;
                background-color: #4f46e5;
                color: white;
                text-decoration: none;
                padding: 12px 30px;
                border-radius: 6px;
                margin: 20px 0;
                font-weight: 600;
            }
            .button:hover {
                background-color: #4338ca;
            }
            .footer {
                text-align: center;
                font-size: 12px;
                color: #6b7280;
                margin-top: 30px;
                padding-top: 20px;
                border-top: 1px solid #e5e7eb;
            }
            .role-badge {
                display: inline-block;
                background-color: #ede9fe;
                color: #4f46e5;
                padding: 2px 10px;
                border-radius: 12px;
                font-size: 13px;
                font-weight: 600;
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">BlitzTask</div>
        </div>

        <div class="content">
            <h1>You've been invited to a project</h1>

            <p>Hi,</p>

            <p><strong>@Model.InviterName</strong> has invited you to join <strong>@Model.ProjectName</strong> on BlitzTask as a <span class="role-badge">@Model.Role</span>.</p>

            <p>Click the button below to accept the invitation and get started:</p>

            <center>
                <a href="@Model.InvitationLink" class="button">Accept Invitation</a>
            </center>

            <p>If you didn't expect this invitation, you can safely ignore this email.</p>
        </div>

        <div class="footer">
            <p>&copy; @DateTime.UtcNow.Year BlitzTask. All rights reserved.</p>
            <p>Questions? Contact us at support@blitztask.com</p>
        </div>
    </div>
</body>
</html>
